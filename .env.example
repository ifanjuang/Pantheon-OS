# ── Base de données ──────────────────────────────────────────────
DB_PASSWORD=changeme

# ── Auth JWT ─────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-secret-min-32-chars-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440          # 24h
ADMIN_EMAIL=admin@agence.fr
ADMIN_PASSWORD=changeme          # à modifier au 1er démarrage

# ── IA — choisir un mode ─────────────────────────────────────────
# MODE LOCAL (Ollama) — aucun abonnement, données 100% locales
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# MODE CLOUD (OpenAI ou compatible) — décommenter si souhaité
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIM=1024

# ── Storage MinIO ─────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=arceus
MINIO_ROOT_PASSWORD=changeme-minio
MINIO_BUCKET=arceus-files
MINIO_SECURE=false

# ── Notion ───────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_DATABASE_AFFAIRES=
NOTION_DATABASE_ACTIONS=

# ── API ──────────────────────────────────────────────────────────
API_PORT=8000
API_WORKERS=1
DEBUG=true

# ── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_LLM=10/minute
RATE_LIMIT_STANDARD=100/minute
RATE_LIMIT_READ=1000/minute

# ── Notifications — SMTP ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@agence.fr
SMTP_PASSWORD=
SMTP_FROM=ARCEUS <notifications@agence.fr>

# ── Notifications — Telegram ──────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# ── Notifications — WhatsApp ──────────────────────────────────────
WHATSAPP_ENABLED=false
WHATSAPP_MODE=meta
WA_PHONE_ID=
WA_TOKEN=
WA_TEMPLATE_NAME=os_projet_alerte
EVOLUTION_API_KEY=changeme-evolution

# ── Redis / ARQ ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Agents ────────────────────────────────────────────────────────
AGENTS_DIR=/agents

# ── Webhooks / Paperclip ─────────────────────────────────────────
# WEBHOOK_SECRET=   # Si vide, JWT_SECRET_KEY est utilisé
