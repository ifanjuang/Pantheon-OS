# ── Database ─────────────────────────────────────────────────────
DB_PASSWORD=changeme

# ── Auth JWT ─────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-secret-min-32-chars-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@pantheon.ai
ADMIN_PASSWORD=changeme

# ── LLM — choose one mode ────────────────────────────────────────
# LOCAL (Ollama) — no subscription, 100% local data
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# CLOUD (OpenAI) — uncomment to switch
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIM=1536

# ── API ──────────────────────────────────────────────────────────
API_PORT=8000
API_WORKERS=1
DEBUG=true

# ── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_LLM=20/minute
RATE_LIMIT_STANDARD=200/minute
RATE_LIMIT_READ=1000/minute

# ── Domain ───────────────────────────────────────────────────────
DOMAIN=architecture
DOMAIN_LABEL=Architecture & Maîtrise d'Œuvre

# ── Notifications — SMTP (optional) ──────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=notifications@yourorg.com
# SMTP_PASSWORD=
# SMTP_FROM=Pantheon OS <notifications@yourorg.com>

# ────────────────────────────────────────────────────────────────
# V2 ONLY — uncomment when using infra/compose/docker-compose.v2.yml
# ────────────────────────────────────────────────────────────────

# Redis / ARQ (background jobs)
# REDIS_URL=redis://redis:6379/0

# MinIO (S3 file storage)
# MINIO_ENDPOINT=minio:9000
# MINIO_ROOT_USER=pantheon
# MINIO_ROOT_PASSWORD=changeme-minio
# MINIO_BUCKET=pantheon-files
# MINIO_SECURE=false
